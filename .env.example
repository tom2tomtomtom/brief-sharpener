# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Stripe
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_SINGLE=price_your-single-price-id
STRIPE_PRICE_ID_PRO=price_your-pro-price-id
STRIPE_PRICE_ID_AGENCY=price_your-agency-price-id

# Optional
NEXT_PUBLIC_URL=https://yourdomain.com

# Budget caps (USD) — protects against free-tier abuse
DAILY_BUDGET_USD=20
MONTHLY_BUDGET_USD=300
DAILY_FREE_BUDGET_USD=10
ADMIN_API_SECRET=your-admin-secret-for-cost-dashboard
